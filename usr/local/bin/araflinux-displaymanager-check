echo
echo "#################################"
echo "Start araflinux-displaymanager-check"
echo "#################################"
echo

package=sddm
if pacman -Qq $package > /dev/null ; then
  ln -sf /usr/lib/systemd/system/sddm.service /etc/systemd/system/display-manager.service
fi

package=lightdm
if pacman -Qq $package > /dev/null ; then
  ln -sf /usr/lib/systemd/system/lightdm.service /etc/systemd/system/display-manager.service
fi

package=gdm
if pacman -Qq $package > /dev/null ; then
    ln -sf /usr/lib/systemd/system/gdm.service /etc/systemd/system/display-manager.service
fi

package=lxdm
if pacman -Qq $package > /dev/null ; then
   ln -sf /usr/lib/systemd/system/lxdm.service /etc/systemd/system/display-manager.service
fi

package=ly
if pacman -Qq $package > /dev/null ; then
  ln -sf /usr/lib/systemd/system/ly.service /etc/systemd/system/display-manager.service
fi

echo
echo "#################################"
echo "End araflinux-displaymanager-check"
echo "#################################"
echo
